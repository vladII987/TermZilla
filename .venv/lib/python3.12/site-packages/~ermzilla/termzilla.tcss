/* TermZilla - Simple Terminal Look */

Screen {
    background: #1a1a2e;
    color: #c0c0c0;
}

/* ── Browser Screen ── */

#banner {
    dock: top;
    height: 3;
    text-align: center;
    color: #00ff88;
    background: #0a0a1a;
    content-align: center middle;
}

#browser-layout {
    height: 1fr;
}

#local-pane {
    width: 1fr;
    height: 100%;
    border-right: solid #444444;
}

#remote-pane {
    width: 1fr;
    height: 100%;
}

#local-title, #remote-title {
    dock: top;
    height: 1;
    color: #888888;
    background: #0a0a1a;
}

#remote-placeholder {
    height: 1fr;
    content-align: center middle;
    color: #444444;
    background: #0a0a1a;
}

FileTable {
    height: 1fr;
    background: #1a1a2e;
}

FileTable:focus {
    border: solid #00ff88;
}

FileTable > .datatable--cursor {
    background: #00ff88;
    color: #1a1a2e;
}

/* Transfer Queue */
#transfer-queue {
    dock: bottom;
    height: auto;
    max-height: 5;
    border-top: solid #444444;
    background: #0a0a1a;
}

/* Status Bar */
#status-bar {
    dock: bottom;
    height: 1;
    background: #0a0a1a;
    color: #888888;
    padding: 0 1;
}

Footer {
    background: #0a0a1a;
    color: #444444;
}
